# Neo4j Configuration - External Cloud Instance
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Neo4j Database Settings
NEO4J_INDEX_NAME=form_10k_chunks
NEO4J_NODE_LABEL=Chunk
NEO4J_TEXT_NODE_PROPERTY=text
NEO4J_EMBEDDING_NODE_PROPERTY=textEmbedding
ALLOW_NEO4J_WRITE_NEO4J_QUERY_ROUTER=false

# Database Availability
CHROMA_DATA_BASE_AVAILABILITY=NO
GRAPH_DATA_BASE_AVAILABILITY=YES

# API Keys (Add your actual keys here)
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Model Configuration
CHAT_MODEL_TYPE=OPENAI
CHAT_MODEL_NAME=gpt-4o
EMBEDDINGS_MODEL_TYPE=OPENAI
EMBEDDINGS_MODEL_NAME=text-embedding-ada-002

# Application Environment
APP_ENV=development
DEBUG_ENABLE=true
LOG_LEVEL=DEBUG

# Other Settings
USE_ONLY_CACHE_NODES=True
SPECIAL_METRIC_CACHE_PRIMARY_SOURCE=yahoo
